{
  "name": "quantpilot",
  "version": "0.1.0",
  "private": true,
  "description": "QuantPilot monorepo skeleton for the platform layer and agent-facing trading workspace",
  "type": "module",
  "engines": {
    "node": ">=20.5.0",
    "npm": ">=10"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "prepare": "node scripts/install-git-hooks.mjs",
    "dev": "vite --config apps/web/vite.config.ts --host 0.0.0.0 --port 8080",
    "start": "vite --config apps/web/vite.config.ts --host 0.0.0.0 --port 8080",
    "build": "vite build --config apps/web/vite.config.ts",
    "preview": "vite preview --config apps/web/vite.config.ts --host 0.0.0.0 --port 8080",
    "check:workspaces": "node scripts/check-workspace-integrity.mjs",
    "check:lockfile": "node scripts/check-lockfile-sync.mjs",
    "check:stage-docs": "node scripts/check-stage-1-docs.mjs",
    "test:api": "node --test apps/api/test/*.test.mjs",
    "test:engine": "node --test packages/task-workflow-engine/test/*.test.mjs",
    "test:runtime": "node --test packages/control-plane-runtime/test/*.test.mjs",
    "test:control-plane": "node --test packages/control-plane-store/test/*.test.mjs",
    "test:worker": "node --test apps/worker/test/*.test.mjs",
    "test:web": "vitest run apps/web/src/modules/console/execution-collection-configs.test.ts apps/web/src/modules/console/execution-inspection-configs.test.ts apps/web/src/modules/console/execution-operations.test.ts apps/web/src/modules/console/execution-panels.test.ts apps/web/src/modules/research/research-panels.test.tsx apps/web/src/modules/research/research-navigation.test.ts apps/web/src/modules/permissions/permissionCopy.test.ts apps/web/src/pages/research-pages.test.tsx --environment node",
    "typecheck": "tsc --noEmit -p apps/web/tsconfig.json",
    "verify": "npm run check:workspaces && npm run check:lockfile && npm run check:stage-docs && npm run test:control-plane && npm run test:runtime && npm run test:engine && npm run test:api && npm run test:worker && npm run test:web && npm run typecheck && npm run build",
    "gateway": "node apps/api/src/main.mjs",
    "worker": "node apps/worker/src/main.mjs"
  },
  "keywords": [
    "quantitative-trading",
    "trading-system",
    "agent-platform",
    "react",
    "vite",
    "react-router"
  ],
  "license": "MIT",
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.14",
    "vitest": "^4.1.0"
  }
}
