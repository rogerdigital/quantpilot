# Frontend
VITE_REFRESH_MS=1800

# simulated | custom-http | alpaca
VITE_MARKET_DATA_PROVIDER=simulated
VITE_MARKET_DATA_HTTP_URL=

# simulated | custom-http | alpaca
VITE_BROKER_PROVIDER=simulated
VITE_BROKER_HTTP_URL=

VITE_ALPACA_PROXY_BASE=/api/alpaca

# Gateway
GATEWAY_PORT=8787
# Keep broker credentials on the gateway or upstream service only.
BROKER_ADAPTER=alpaca
BROKER_UPSTREAM_URL=
BROKER_UPSTREAM_API_KEY=
BROKER_UPSTREAM_AUTH_SCHEME=Bearer
ALPACA_KEY_ID=
ALPACA_SECRET_KEY=
ALPACA_USE_PAPER=true
ALPACA_DATA_FEED=iex
